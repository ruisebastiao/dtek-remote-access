# Dev: keep auth permissive until the Hub tile/cookie is wired.
DEV_AUTH=true
DATABASE_URL=sqlite:///./remote_access_dev.db

# Production/shared with dtek-webhub.
JWT_SECRET=
JWT_ALGORITHM=HS256
COOKIE_NAME=dtek_sso
HUB_URL=https://hub.dreamforit.com

# Optional read-only Headscale integration.
HEADSCALE_URL=
HEADSCALE_API_KEY=
HEADSCALE_TIMEOUT=5

# Dev ports used by this service.
CORS_ORIGINS=http://localhost:8003,http://127.0.0.1:8003
